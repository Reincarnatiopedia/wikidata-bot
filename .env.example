# Wikidata bot credentials (required)
# Create a bot password at: https://www.wikidata.org/wiki/Special:BotPasswords
WIKIDATA_BOT_USER=YourUsername@YourBotName
WIKIDATA_BOT_PASS=your_bot_password_here

# User-Agent for Wikidata API (recommended to customize)
WIKIDATA_USER_AGENT=WikidataBot/1.0 (https://your-site.com; mailto:your@email.com)

# DeepSeek API key (optional, for LLM-based translations)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Gemini API keys (optional, comma-separated for rotation)
GEMINI_API_KEYS=key1,key2,key3

# Ollama local LLM (optional, defaults shown)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=deepseek-r1:14b

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=your_chat_id

# Report log paths (optional)
WARMUP_LOG=logs/wikidata_warmup.log
LATVIAN_LOG=logs/wikidata_latvian.log
